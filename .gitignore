# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Env / secrets
.env
.env.*
!.env.example
*.key
secrets/

# Corpus & course materials — track the STRUCTURE, never the content.
# corpus/ holds owned course material, used locally only. The skeleton
# (folder layout + README + .gitkeep) is versioned so the ingestion
# convention is reproducible; every actual source file stays out of git.
data/
corpus/**
!corpus/
!corpus/**/
!corpus/README.md
!corpus/**/.gitkeep
*.pdf
*.docx
!docs/demo-walkthrough-with-screenshots.docx
*.pptx
*.jsonl
*_transcript.txt

# Generated artifacts / stores (can embed corpus or PII — never commit)
*.sqlite
*.sqlite3
*.db
chroma/
.chroma/
*.faiss
*.index
models/
eval/extraction_report.json
eval/runs/
*.log

# Notebooks / scratch
.ipynb_checkpoints/
scratch/
tmp/

# AI workflow runtime state (superpowers brainstorm / visual-companion) — never commit
.superpowers/

# OS / editor
.DS_Store
.idea/
.vscode/
