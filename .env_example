# Copy this file to .env, then paste real secrets where values are empty/placeholders.
# Do not commit .env.

# Active generation provider for live teach-loop demo/eval.
GENACADEMY_PROVIDER=nebius

# Nebius Token Factory generation call.
NEBIUS_API_KEY=paste-your-nebius-api-key-here
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/
NEBIUS_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

# Coach local artifact paths and collection settings.
# Uncomment only when overriding local defaults.
# GENACADEMY_COACH_ROOT=/absolute/path/to/genacademy-coach
# GENACADEMY_COACH_DATA_DIR=/absolute/path/to/genacademy-coach/data
GENACADEMY_COACH_SQLITE_FILENAME=genacademy-coach.sqlite
# GENACADEMY_COACH_CORPUS_DIR=/absolute/path/to/genacademy-coach/corpus
# GENACADEMY_COACH_EVAL_QUESTIONS_DIR=/absolute/path/to/genacademy-coach/corpus/eval-questions
# GENACADEMY_COACH_TRACE_DIR=/absolute/path/to/genacademy-coach/traces
GENACADEMY_COACH_COLLECTION=coach_course
GENACADEMY_COACH_TOP_K=5
GENACADEMY_COACH_CANDIDATE_K=20
GENACADEMY_COACH_SOURCE_PRIORITY=slide,handout,note,transcript

# Teach-loop evidence thresholds and turn budget.
GENACADEMY_COACH_STOP_THRESHOLD=0.40
GENACADEMY_COACH_CONFIRM_THRESHOLD=0.85
GENACADEMY_COACH_MAX_TURNS=4

# Week-2 RAG settings reused by the Coach foundation.
GENACADEMY_CHUNKER=section
# Uncomment only when overriding Week-2 defaults. Coach overrides retrieval storage from
# GENACADEMY_COACH_DATA_DIR during Foundation.build().
# GENACADEMY_DATA_DIR=/absolute/path/to/data
# GENACADEMY_CHROMA_DIR=/absolute/path/to/chroma
# GENACADEMY_SQLITE=/absolute/path/to/genacademy.sqlite
GENACADEMY_TOP_K=5
GENACADEMY_CHUNK_SIZE=1000
GENACADEMY_CHUNK_OVERLAP=150
GENACADEMY_SECTION_CHUNK_MAX_CHARS=1500
GENACADEMY_SECTION_CHUNK_OVERLAP=150

# Embeddings. Keep local embeddings unless intentionally re-ingesting a fresh collection.
GENACADEMY_EMBEDDINGS=local
GENACADEMY_EMBED_MODEL=all-MiniLM-L6-v2
GENACADEMY_EMBED_DIM=384
NEBIUS_EMBED_MODEL=Qwen/Qwen3-Embedding-8B

# Optional reranking. Disabled by default for local MVP runs.
GENACADEMY_RERANK_ENABLED=false
GENACADEMY_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
GENACADEMY_RERANK_LOCAL_FILES_ONLY=true
GENACADEMY_RERANK_BATCH_SIZE=32
GENACADEMY_RERANK_POOL=0
# GENACADEMY_RERANK_DEVICE=cpu
# GENACADEMY_RERANK_CACHE_DIR=/absolute/path/to/rerank-cache

# Optional providers retained from Week-2 provider surface.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
GEMMA_BASE_URL=http://127.0.0.1:8085/v1
GEMMA_MODEL=gemma-3-12b-it

# Local auth/session defaults inherited by Week-2 settings.
GENACADEMY_SESSION_SECRET=dev-only-change-me
GENACADEMY_SECURE_COOKIES=false

# Optional LangSmith companion tracing. The local JSON trace is still the MVP proof artifact.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=genacademy-coach

# Optional Hugging Face token for faster local model downloads.
HF_TOKEN=
